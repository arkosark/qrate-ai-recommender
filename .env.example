# Database (same as other QRate services)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=menucrawler

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
TITAN_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# DynamoDB
DYNAMODB_SESSIONS_TABLE=recommendation-sessions-dev
DYNAMODB_ENDPOINT=  # local dev only

# Cognito (same as other services)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=us-east-1

# Environmental APIs
WEATHER_API_KEY=       # OpenWeatherMap
PREDICTHQ_API_KEY=     # Local event signals

# Service
PORT=8004
ENVIRONMENT=dev

# Optional: override Bedrock endpoint (for WireMock local testing)
BEDROCK_ENDPOINT=
